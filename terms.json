        { "acronym": "SC", "fullForm": "Subscriber Connector", "definition": "Fiber connector with push-pull coupling" },
        { "acronym": "ST", "fullForm": "Straight Tip", "definition": "Fiber connector with bayonet-style coupling" },
        { "acronym": "MPO", "fullForm": "Multifiber Push-On", "definition": "High-density connector for 12-24 fibers" },
        { "acronym": "RJ", "fullForm": "Registered Jack", "definition": "Standardized telecom interface (RJ-45, RJ-11)" },
        { "acronym": "DAC", "fullForm": "Direct Attach Copper", "definition": "Short-range copper cable for high-speed links" },
        { "acronym": "FC", "fullForm": "Fibre Channel", "definition": "High-speed SAN protocol on optical fiber" },
        { "acronym": "QSFP", "fullForm": "Quad Small Form-factor Pluggable", "definition": "Hot-pluggable transceiver for 40/100GbE" },
        { "acronym": "SFP", "fullForm": "Small Form-factor Pluggable", "definition": "Hot-pluggable transceiver for Gigabit Ethernet" },
        { "acronym": "TX", "fullForm": "Transmitter", "definition": "Component sending signals on network interface" },
        { "acronym": "RX", "fullForm": "Receiver", "definition": "Component receiving signals on network interface" },
        { "acronym": "CRC", "fullForm": "Cyclic Redundancy Check", "definition": "Error-detecting code appended to frames" },
        { "acronym": "MTU", "fullForm": "Maximum Transmission Unit", "definition": "Largest Layer 3 packet size without fragmentation" },
        { "acronym": "PoE", "fullForm": "Power over Ethernet", "definition": "IEEE 802.3 standard delivering DC power over cables" },
        { "acronym": "UPS", "fullForm": "Uninterruptible Power Supply", "definition": "Battery-backed device for temporary power" },
        { "acronym": "PDU", "fullForm": "Power Distribution Unit", "definition": "Rack-mounted device distributing electrical power" },
        { "acronym": "STP", "fullForm": "Shielded Twisted Pair", "definition": "Copper cabling with foil/braid shielding" },
        { "acronym": "UTP", "fullForm": "Unshielded Twisted Pair", "definition": "Most common Ethernet cabling (Cat5e/6/6a)" },
        { "acronym": "CPU", "fullForm": "Central Processing Unit", "definition": "Hardware executing control-plane instructions" }
